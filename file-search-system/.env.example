# File Search System - Environment Configuration
# Copy this file to .env and modify as needed

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=file_search
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable
DB_MAX_CONNECTIONS=10

# Server Configuration
SERVER_HOST=localhost
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s

# Indexing Configuration
INDEXING_PATHS=/Users,/Documents,/Projects
INDEXING_IGNORE_PATTERNS=*.tmp,node_modules/**,.git/**,.DS_Store,*.log
INDEXING_MAX_FILE_SIZE=100MB
INDEXING_CHUNK_SIZE=512
INDEXING_CHUNK_OVERLAP=50

# Performance Configuration
PERFORMANCE_CPU_THRESHOLD=90
PERFORMANCE_MEMORY_THRESHOLD=90
PERFORMANCE_FILES_PER_MINUTE=60
PERFORMANCE_EMBEDDINGS_PER_MINUTE=120
PERFORMANCE_SEARCHES_PER_MINUTE=300

# Embeddings Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=30s
OLLAMA_MAX_RETRIES=3

# Search Configuration
SEARCH_VECTOR_WEIGHT=0.6
SEARCH_BM25_WEIGHT=0.3
SEARCH_METADATA_WEIGHT=0.1
SEARCH_CACHE_TTL=1h
SEARCH_CACHE_SIZE=1000

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=logs/app.log

# Development Configuration
DEV_MODE=true
DEV_HOT_RELOAD=true
DEV_DEBUG=false