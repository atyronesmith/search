{
  "name": "file-search-frontend",
  "version": "1.0.0",
  "description": "File Search System Frontend - Electron + React",
  "main": "public/electron.js",
  "private": true,
  "homepage": "./",
  "dependencies": {
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.5.2",
    "axios": "^1.15.0",
    "classnames": "^2.3.2",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "^5.0.1",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^2.0.0",
    "wait-on": "^7.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm start\" \"wait-on http://localhost:3000 && electron .\"",
    "build-electron": "npm run build && electron-builder",
    "dist": "npm run build && electron-builder --publish=never"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "nth-check": ">=2.0.1",
    "postcss": ">=8.4.31",
    "serialize-javascript": ">=7.0.5",
    "webpack-dev-server": ">=5.2.1",
    "underscore": ">=1.13.8",
    "@tootallnate/once": ">=3.0.1",
    "minimatch": ">=9.0.7",
    "tar": ">=7.5.11",
    "node-forge": ">=1.4.0",
    "yaml": ">=2.8.3",
    "flatted": ">=3.4.2",
    "glob": ">=10.5.0",
    "rollup": ">=2.80.0",
    "ajv": ">=8.18.0",
    "brace-expansion": ">=2.0.3",
    "picomatch": ">=4.0.4",
    "qs": ">=6.14.2",
    "webpack": ">=5.104.1",
    "path-to-regexp": ">=0.1.13",
    "@xmldom/xmldom": ">=0.8.12",
    "lodash": ">=4.18.0",
    "js-yaml": ">=4.1.1",
    "axios": "$axios"
  },
  "build": {
    "appId": "com.filesearch.app",
    "productName": "File Search System",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "public/electron.js",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
