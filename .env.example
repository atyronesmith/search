# Database Configuration
DATABASE_URL=postgresql://username:@localhost:5432/database_name
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_DIM=768
OLLAMA_TIMEOUT=30

# API Server Configuration
API_HOST=127.0.0.1
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# Indexing Configuration
INDEX_BATCH_SIZE=32
INDEX_MAX_FILE_SIZE_MB=100
INDEX_CHUNK_SIZE=512
INDEX_CHUNK_OVERLAP=64

# File Monitoring
WATCH_PATHS=~/Documents,~/Desktop,~/Downloads
WATCH_INTERVAL_SECONDS=5
WATCH_IGNORE_PATTERNS=.*,~*,*.tmp,__pycache__,node_modules,.git

# Resource Management
CPU_THRESHOLD_PERCENT=70
MEMORY_THRESHOLD_PERCENT=80
RATE_LIMIT_FILES_PER_MINUTE=60
RATE_LIMIT_EMBEDDINGS_PER_MINUTE=120

# Search Configuration
SEARCH_VECTOR_WEIGHT=0.6
SEARCH_BM25_WEIGHT=0.3
SEARCH_METADATA_WEIGHT=0.1
SEARCH_CACHE_TTL_MINUTES=15
SEARCH_DEFAULT_LIMIT=20

# Frontend Configuration
ELECTRON_DEV_SERVER_URL=http://localhost:5173
ELECTRON_IS_DEV=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=file_search.log
LOG_FORMAT=json

# Service Configuration
SERVICE_NAME=FileSearchService
SERVICE_AUTO_START=true
SERVICE_START_DELAY_SECONDS=10

# Document Processing
DOCLING_ENABLED=true
DOCLING_SERVICE_URL=http://localhost:8082
