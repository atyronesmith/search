{
  "name": "file-search-frontend",
  "version": "1.0.0",
  "description": "Electron + React frontend for file search system",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron": "electron .",
    "electron-dev": "ELECTRON_IS_DEV=1 electron .",
    "pack": "electron-builder",
    "prepack": "npm run build",
    "dev": "concurrently \"npm start\" \"wait-on http://localhost:3000 && npm run electron-dev\""
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "^5.15.14",
    "@mui/material": "^5.15.14",
    "@mui/x-data-grid": "^7.0.0",
    "@mui/x-date-pickers": "^6.20.2",
    "axios": "^1.15.0",
    "chart.js": "^4.4.2",
    "date-fns": "^2.30.0",
    "highlight.js": "^11.9.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.14.0",
    "react-scripts": "^5.0.1",
    "react-syntax-highlighter": "^15.5.0",
    "recharts": "^2.12.3",
    "socket.io-client": "^4.8.3",
    "typescript": "^4.9.5",
    "web-vitals": "^3.5.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.73",
    "@types/react-dom": "^18.2.23",
    "@types/react-syntax-highlighter": "^15.5.11",
    "concurrently": "^8.2.2",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^7.2.0"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "nth-check": ">=2.0.1",
    "postcss": ">=8.4.31",
    "serialize-javascript": ">=7.0.5",
    "webpack-dev-server": ">=5.2.1",
    "underscore": ">=1.13.8",
    "@tootallnate/once": ">=3.0.1",
    "svgo": ">=2.8.1",
    "minimatch": ">=9.0.7",
    "tar": ">=7.5.11",
    "node-forge": ">=1.4.0",
    "yaml": ">=2.8.3",
    "flatted": ">=3.4.2",
    "glob": ">=10.5.0",
    "rollup": ">=2.80.0",
    "ajv": ">=8.18.0",
    "brace-expansion": ">=2.0.3",
    "picomatch": ">=4.0.4",
    "prismjs": ">=1.30.0",
    "qs": ">=6.14.2",
    "webpack": ">=5.104.1",
    "path-to-regexp": ">=0.1.13",
    "@xmldom/xmldom": ">=0.8.12",
    "lodash": ">=4.18.0",
    "socket.io-parser": ">=4.2.6",
    "jsonpath": ">=1.3.0",
    "js-yaml": ">=4.1.1",
    "axios": "$axios",
    "react-router": ">=6.30.2",
    "@remix-run/router": ">=1.23.2",
    "mdast-util-to-hast": ">=13.2.1",
    "socket.io-parser": ">=4.2.6"
  },
  "build": {
    "extends": null,
    "appId": "com.filesearch.app",
    "productName": "File Search",
    "directories": {
      "output": "dist",
      "buildResources": "public"
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
